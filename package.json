{
  "name": "minglo-blog",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write \"apps/**/*.ts\"",
    "format:prisma": "prisma format",
    "lint": "eslint \"{src,apps,test}/**/*.ts\" --fix",
    "test": "jest",
    "build:minglo-blog": "nest build minglo-blog",
    "start:minglo-blog": "nest start minglo-blog",
    "start:minglo-blog:dev": "cross-env NODE_ENV=development nest start minglo-blog --watch",
    "start:minglo-blog:debug": "cross-env NODE_ENV=development nest start minglo-blog --debug --watch",
    "start:minglo-blog:prod": "cross-env NODE_ENV=production node -r ./newrelic.js dist/apps/minglo-blog/main",
    "test:minglo-blog:watch": "cross-env NODE_ENV=test jest --project apps/minglo-blog --watch",
    "test:minglo-blog:cov": "cross-env NODE_ENV=test jest --project apps/minglo-blog --coverage",
    "test:minglo-blog:debug": "cross-env NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand --project apps/minglo-blog",
    "test:minglo-blog:e2e": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config apps/minglo-blog/test/jest-e2e.json --runInBand",
    "test:minglo-blog:unit": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config apps/minglo-blog/test/jest-unit.json --runInBand",
    "migrate:minglo-blog:dev": "cross-env NODE_ENV=development prisma migrate dev --config apps/minglo-blog/prisma.config.ts",
    "migrate:minglo-blog:test": "cross-env NODE_ENV=test prisma migrate reset --force --config apps/minglo-blog/prisma.config.ts",
    "migrate:minglo-blog:deploy": "cross-env NODE_ENV=production prisma migrate deploy --config apps/minglo-blog/prisma.config.ts",
    "migrate:minglo-blog:reset": "cross-env NODE_ENV=development prisma migrate reset --config apps/minglo-blog/prisma.config.ts",
    "migrate:minglo-blog:status": "cross-env NODE_ENV=development prisma migrate status --config apps/minglo-blog/prisma.config.ts",
    "prisma:minglo-blog:generate": "cross-env NODE_ENV=development prisma generate --config apps/minglo-blog/prisma.config.ts",
    "prisma:minglo-blog:generate-test": "cross-env NODE_ENV=test prisma generate --config apps/minglo-blog/prisma.config.ts",
    "prisma:minglo-blog:generate:prod": "cross-env NODE_ENV=production prisma generate --config apps/minglo-blog/prisma.config.ts",
    "build:minglo-media-service": "nest build minglo-media-service",
    "start:minglo-media-service": "nest start minglo-media-service",
    "start:minglo-media-service:dev": "cross-env NODE_ENV=development nest start minglo-media-service --watch",
    "start:minglo-media-service:debug": "cross-env NODE_ENV=development nest start minglo-media-service --debug --watch",
    "start:minglo-media-service:prod": "cross-env NODE_ENV=production node -r ./newrelic.js dist/apps/minglo-media-service/main",
    "test:minglo-media-service:watch": "cross-env NODE_ENV=test jest --project apps/minglo-media-service --watch",
    "test:minglo-media-service:cov": "cross-env NODE_ENV=test jest --project apps/minglo-media-service --coverage",
    "test:minglo-media-service:debug": "cross-env NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand --project apps/minglo-blog",
    "test:minglo-media-service:e2e": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config apps/minglo-media-service/test/jest-e2e.json --runInBand",
    "test:minglo-media-service:unit": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config apps/minglo-media-service/test/jest-unit.json --runInBand",
    "migrate:minglo-media-service:dev": "cross-env NODE_ENV=development prisma migrate dev --config apps/minglo-media-service/prisma.config.ts",
    "migrate:minglo-media-service:test": "cross-env NODE_ENV=test prisma migrate reset --force --config apps/minglo-media-service/prisma.config.ts",
    "migrate:minglo-media-service:deploy": "cross-env NODE_ENV=production prisma migrate deploy --config apps/minglo-media-service/prisma.config.ts",
    "migrate:minglo-media-service:reset": "cross-env NODE_ENV=development prisma migrate reset --config apps/minglo-media-service/prisma.config.ts",
    "migrate:minglo-media-service:status": "cross-env NODE_ENV=development prisma migrate status --config apps/minglo-media-service/prisma.config.ts",
    "prisma:minglo-media-service:generate": "cross-env NODE_ENV=development prisma generate --config apps/minglo-media-service/prisma.config.ts",
    "prisma:minglo-media-service:generate-test": "cross-env NODE_ENV=test prisma generate --config apps/minglo-media-service/prisma.config.ts",
    "prisma:minglo-media-service:generate:prod": "cross-env NODE_ENV=production prisma generate --config apps/minglo-media-service/prisma.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/microservices": "^11.1.18",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "form-data": "^4.0.5",
    "multer": "^2.1.1",
    "newrelic": "^13.16.0",
    "nodemailer": "^8.0.2",
    "p-limit": "^7.3.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-oauth2": "^1.8.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0",
    "ua-parser-js": "^2.0.9",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/form-data": "^2.5.2",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/newrelic": "^9.14.8",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-oauth2": "^1.8.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.3.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/decorators(|/.*)$": "<rootDir>/libs/decorators/src/$1",
      "^@app/dynamic-config(|/.*)$": "<rootDir>/libs/dynamic-config/src/$1",
      "^@app/exceptions(|/.*)$": "<rootDir>/libs/exceptions/src/$1",
      "^@app/logger(|/.*)$": "<rootDir>/libs/logger/src/$1",
      "^@app/media(|/.*)$": "<rootDir>/libs/media/src/$1",
      "^@app/notifications(|/.*)$": "<rootDir>/libs/notifications/src/$1",
      "^@app/setup(|/.*)$": "<rootDir>/libs/setup/src/$1"
    }
  }
}
