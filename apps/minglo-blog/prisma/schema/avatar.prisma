model Avatar {
  id        Int       @id @default(autoincrement())
  publicId  String    @unique @default(cuid()) @map("public_id")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  profileId Int     @unique @map("profile_id")
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  urlLarge      String @map("url_large")
  keyLarge      String @map("key_large")
  fileSizeLarge Int    @map("file_size_large")
  widthLarge    Int    @map("width_large")
  heightLarge   Int    @map("height_large")

  urlSmall      String @map("url_small")
  keySmall      String @map("key_small")
  fileSizeSmall Int    @map("file_size_small")
  widthSmall    Int    @map("width_small")
  heightSmall   Int    @map("height_small")

  mimeType MediaMimeType @map("mime_type")

  @@index([profileId, deletedAt])
  @@index([deletedAt])
  @@map("avatar")
}
