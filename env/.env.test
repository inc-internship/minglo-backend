# Port where Minglo Blog API will run
MINGLO_PORT=4000

# Database connection string
MINGLO_DB_URL=postgresql://neondb_owner:npg_AS0cbQvB1rKz@ep-rough-bird-a4j1wywb-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Enable testing module (used for e2e tests and database cleaning)
# true | false
MINGLO_TESTING_MODULE=true

# Enable Swagger API documentation
# true | false
MINGLO_SWAGGER=true

# Enable trust proxy (needed when running behind reverse proxy like Nginx, Cloudflare, etc.)
# true | false
MINGLO_TRUST_PROXY=false

# Enable cors
# true | false
MINGLO_CORS=false

# Allowed origins for CORS requests (comma-separated list)
# example: http://localhost:3000,https://minglo.blog
MINGLO_CORS_ORIGINS=

# Enable sending cookies and credentials in CORS requests
# true | false
MINGLO_CORS_CREDENTIALS=false

# Enable cookie parser middleware
# true | false
MINGLO_COOKIE_PARSER=true

# Time window for throttling in seconds
MINGLO_THROTTLE_TTL=10

# Maximum number of requests allowed per TTL
MINGLO_THROTTLE_LIMIT=5

# Mail service provider (e.g., Gmail, Yahoo)
MAIL_SERVICE=Gmail

# Mail account address used to send emails (e.g., example@gmail.com)
MAIL_ADDRESS=example@gmail.com

# Mail account password (set a secure password)
MAIL_PASS=app-secret-pass

# Mail sender displayed in emails (e.g., "Account Name" <example@gmail.com>)
MAIL_FROM='minglo.blog (no-reply)'

#access secret
ACCESS_SECRET=access-token-secret

#access ttl
MAX_AGE_ACCESS_TOKEN=10

#refresh secret
REFRESH_SECRET=refresh-token-secret

#refresh ttl
MAX_AGE_REFRESH_TOKEN=20

# --------- Logger Service ---------
# New Relic logs ingestion host (used to send logs via HTTP)
# Keep empty for test
# example: log-api.newrelic.com
LOGGER_HOST=

# New Relic logs API path with license key for authentication
# Keep empty for test
# format: /log/v1?Api-Key=YOUR_NEW_RELIC_LICENSE_KEY
LOGGER_URL_PATH=

# Minimum log level to be sent
# available levels: trace | debug | info | warn | error | fatal
# example: info (recommended for production), debug (for development), error (for test)
LOGGER_LEVEL=error

# New Relic License Key
LOGGER_LICENSE_KEY=

# --------- Recaptcha ---------
# recaptcha secret
RECAPTCHA_SECRET=recaptcha-secret

# recaptcha bypass secret for swagger tests
RECAPTCHA_BYPASS_SECRET=recaptcha-bypass-secret

# --------- OAuth ---------
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/oauth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/oauth/github/callback

# Frontend redirect URL after OAuth
FRONTEND_OAUTH_REDIRECT_URL=http://localhost:4000/api/v1

# --------- Media Service ---------
# Media Service url for internal communication between services
MEDIA_SERVICE_URL=http://localhost:4001

# Internal microservice communication (NestJS TCP)
# Dev: localhost
# Docker/CI: media-service (Docker DNS)
MEDIA_SERVICE_HOST=localhost

# Port where Media Service HTTP API will run
MEDIA_HTTP_PORT=4001

# TCP port for internal microservice communication (NestJS transport)
MEDIA_TCP_PORT=4002

# Database connection string for Media Service
MEDIA_DB_URL=postgresql://local-test-media-db-connections-string

# S3 bucket name used to store media files
S3_BUCKET_NAME=some-bucket-name

# S3 region
S3_REGION=some-region

# S3 access key ID (service account credentials)
S3_ACCESS_KEY_ID=some-access-key-id

# S3 secret access key (keep it secure, do not expose)
S3_SECRET_ACCESS_KEY=some-access-key

# S3 endpoint string
S3_ENDPOINT=https://storage.yandexcloud.net

# Max number of concurrent S3 uploads
# Recommended: 3–8 depending on file size and server load
S3_CONCURRENCY=4

# Max number of concurrent image processing tasks (sharp)
# Recommended: 2–4 depending on CPU cores
IMAGE_PROCESSING_CONCURRENCY=2

# Secret used to sign media-related access tokens
MEDIA_ACCESS_SECRET=jwt-media-access-secret

# Media access token ttl
MEDIA_ACCESS_TOKEN_EXP_IN=60

# Time window for throttling in seconds
MEDIA_THROTTLE_TTL=10

# Maximum number of requests allowed per TTL
MEDIA_THROTTLE_LIMIT=5

# Enable testing module (used for e2e tests and database cleaning)
# true | false
MEDIA_TESTING_MODULE=true

# Enable Swagger API documentation
# true | false
MEDIA_SWAGGER=true

# =========================
# Payments Service Config
# =========================

# Port where Payments Service HTTP API will run
PAYMENTS_PORT=4003

# Database connection string for Payments Service
PAYMENTS_DB_URL=postgresql://local-test-payments-db-connections-string

# Stripe publishable key (used on frontend to initialize Stripe) safe to expose in browser
PAYMENTS_STRIPE_PUBLIC_KEY=stripe-public-key

# Stripe secret key (used on backend to interact with Stripe API) used for creating payments, sessions, refunds, etc.
PAYMENTS_STRIPE_SECRET_KEY=stripe-secret-key

# Stripe webhook signing secret (used to verify webhook events from Stripe)
# for local development: use secret from Stripe CLI (stripe listen)
# for production: use secret from Stripe Dashboard
PAYMENTS_STRIPE_WEBHOOK_SECRET=local-stripe-whsec-secret

# Enable Swagger API documentation
# true | false
PAYMENTS_SWAGGER=true

# Frontend application base URL
# Used for redirects after payment (success / cancel pages)
PAYMENTS_FRONTEND_URL=http://localhost:3000

# Time window for throttling in seconds
PAYMENTS_THROTTLE_TTL=10

# Maximum number of requests allowed per TTL
PAYMENTS_THROTTLE_LIMIT=5

# RabbitMQ connection URL for event-driven communication
RABBITMQ_URL=amqp://local-test-payments-amqp-connections-string
