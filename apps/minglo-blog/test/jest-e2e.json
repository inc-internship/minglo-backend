{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "@app/dynamic-config/(.*)": "<rootDir>/../../../libs/dynamic-config/src/$1",
    "@app/dynamic-config": "<rootDir>/../../../libs/dynamic-config/src",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
