model Profile {
  id        Int       @id @default(autoincrement())
  publicId  String    @unique @default(cuid()) @map("public_id")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  // profile info:
  userName      String @map("user_name") @db.VarChar(255)
  firstName     String @map("first_name") @db.VarChar(255)
  lastName      String @map("last_name") @db.VarChar(255)
  birthday      DateTime? @db.Timestamptz
  countryId     String @map("country_id") @db.VarChar(255)
  cityId        String @map("city_id") @db.VarChar(255)
  aboutMe       String @map("about_me") @db.VarChar(255)

  avatar   Avatar?

  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@map("profile")
}
