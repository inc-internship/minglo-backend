{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/minglo-blog/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/minglo-blog/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/minglo-blog",
  "projects": {
    "decorators": {
      "type": "library",
      "root": "libs/decorators",
      "entryFile": "index",
      "sourceRoot": "libs/decorators/src",
      "compilerOptions": {
        "tsConfigPath": "libs/decorators/tsconfig.lib.json"
      }
    },
    "dynamic-config": {
      "type": "library",
      "root": "libs/dynamic-config",
      "entryFile": "index",
      "sourceRoot": "libs/dynamic-config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/dynamic-config/tsconfig.lib.json"
      }
    },
    "exceptions": {
      "type": "library",
      "root": "libs/exceptions",
      "entryFile": "index",
      "sourceRoot": "libs/exceptions/src",
      "compilerOptions": {
        "tsConfigPath": "libs/exceptions/tsconfig.lib.json"
      }
    },
    "minglo-blog": {
      "type": "application",
      "root": "apps/minglo-blog",
      "entryFile": "main",
      "sourceRoot": "apps/minglo-blog/src",
      "compilerOptions": {
        "tsConfigPath": "apps/minglo-blog/tsconfig.app.json"
      }
    },
    "notifications": {
      "type": "library",
      "root": "libs/notifications",
      "entryFile": "index",
      "sourceRoot": "libs/notifications/src",
      "compilerOptions": {
        "tsConfigPath": "libs/notifications/tsconfig.lib.json"
      }
    },
    "setup": {
      "type": "library",
      "root": "libs/setup",
      "entryFile": "index",
      "sourceRoot": "libs/setup/src",
      "compilerOptions": {
        "tsConfigPath": "libs/setup/tsconfig.lib.json"
      }
    },
    "utils": {
      "type": "library",
      "root": "libs/utils",
      "entryFile": "index",
      "sourceRoot": "libs/utils/src",
      "compilerOptions": {
        "tsConfigPath": "libs/utils/tsconfig.lib.json"
      }
    }
  }
}