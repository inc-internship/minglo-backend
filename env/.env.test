# Port where Minglo Blog API will run
MINGLO_PORT=4000

# Database connection string
MINGLO_DB_URL=postgresql://neondb_owner:npg_AS0cbQvB1rKz@ep-rough-bird-a4j1wywb-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Enable testing module (used for e2e tests and database cleaning)
# true | false
MINGLO_TESTING_MODULE=true

# Enable Swagger API documentation
# true | false
MINGLO_SWAGGER=true

# Enable trust proxy (needed when running behind reverse proxy like Nginx, Cloudflare, etc.)
# true | false
MINGLO_TRUST_PROXY=false

# Enable cors
# true | false
MINGLO_CORS=false

# Allowed origins for CORS requests (comma-separated list)
# example: http://localhost:3000,https://minglo.blog
MINGLO_CORS_ORIGINS=

# Enable sending cookies and credentials in CORS requests
# true | false
MINGLO_CORS_CREDENTIALS=false

# Enable cookie parser middleware
# true | false
MINGLO_COOKIE_PARSER=true

# Time window for throttling in seconds
MINGLO_THROTTLE_TTL=10

# Maximum number of requests allowed per TTL
MINGLO_THROTTLE_LIMIT=5

# Mail service provider (e.g., Gmail, Yahoo)
MAIL_SERVICE=Gmail

# Mail account address used to send emails (e.g., example@gmail.com)
MAIL_ADDRESS=example@gmail.com

# Mail account password (set a secure password)
MAIL_PASS=app-secret-pass

# Mail sender displayed in emails (e.g., "Account Name" <example@gmail.com>)
MAIL_FROM='"Example" <example@gmail.com>'

#access secret
ACCESS_SECRET=12345

#access ttl
MAX_AGE_ACCESS_TOKEN=600

#refresh secret
REFRESH_SECRET=1234567890

#refresh ttl
MAX_AGE_REFRESH_TOKEN=1200

# New Relic logs ingestion host (used to send logs via HTTP)
# Keep empty for test
# example: log-api.newrelic.com
LOGGER_HOST=

# New Relic logs API path with license key for authentication
# Keep empty for test
# format: /log/v1?Api-Key=YOUR_NEW_RELIC_LICENSE_KEY
LOGGER_URL_PATH=

# Minimum log level to be sent
# available levels: trace | debug | info | warn | error | fatal
# example: info (recommended for production), debug (for development), error (for test)
LOGGER_LEVEL=error

# New Relic License Key
LOGGER_LICENSE_KEY=

