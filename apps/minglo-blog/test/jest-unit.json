{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".unit-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "@app/decorators/(.*)": "<rootDir>/../../../libs/decorators/src/$1",
    "@app/decorators": "<rootDir>/../../../libs/decorators/src",
    "@app/dynamic-config/(.*)": "<rootDir>/../../../libs/dynamic-config/src/$1",
    "@app/dynamic-config": "<rootDir>/../../../libs/dynamic-config/src",
    "@app/exceptions/(.*)": "<rootDir>/../../../libs/exceptions/src/$1",
    "@app/exceptions": "<rootDir>/../../../libs/exceptions/src",
    "@app/notifications/(.*)": "<rootDir>/../../../libs/notifications/src/$1",
    "@app/notifications": "<rootDir>/../../../libs/notifications/src",
    "@app/setup/(.*)": "<rootDir>/../../../libs/setup/src/$1",
    "@app/setup": "<rootDir>/../../../libs/setup/src",
    "@app/payments/(.*)": "<rootDir>/../../../libs/payments/src/$1",
    "@app/payments": "<rootDir>/../../../libs/payments/src",
    "@app/logger/(.*)": "<rootDir>/../../../libs/logger/src/$1",
    "@app/logger": "<rootDir>/../../../libs/logger/src",
    "@app/media/(.*)": "<rootDir>/../../../libs/media/src/$1",
    "@app/media": "<rootDir>/../../../libs/media/src",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
